{
  "api": {
    "baseUrl": "http://127.0.0.1:8000",
    "timeoutMs": 30000,
    "endpoints": {
      "adminLogin": "/admin/login",
      "candidateToken": "/candidate/token",
      "jobs": "/api/hr/jobs",
      "job": "/api/hr/jobs/{jobId}",
      "jobApplications": "/api/hr/jobs/{jobId}/applications",
      "jobRecords": "/api/hr/jobs/{jobId}/records",
      "quickSelect": "/api/hr/jobs/{jobId}/quick-select",
      "application": "/api/hr/applications/{applicationId}",
      "applicationDecision": "/api/hr/applications/{applicationId}/hr-decision",
      "resumeUpload": "/api/resume/upload",
      "resumeBulkUpload": "/api/resume/bulk-upload",
      "resumeDownload": "/api/hr/applications/{applicationId}/resume/download",
      "resumeView": "/api/hr/applications/{applicationId}/resume/view",
      "atsScore": "/api/ats/score/{applicationId}",
      "atsDecision": "/api/ats/{applicationId}/decision",
      "questionBank": "/api/hr/jobs/{jobId}/question-bank",
      "questionBankSave": "/api/hr/question-bank/questions",
      "questionBankParseUpload": "/api/hr/question-bank/parse-upload",
      "questionBankQuestion": "/api/hr/question-bank/questions/{questionId}",
      "questionBankClear": "/api/hr/question-bank?job_id={jobId}",
      "configureData": "/api/interviews/{applicationId}/configure-data",
      "configureQuestions": "/api/interviews/{applicationId}/configure-questions",
      "createInterviewLink": "/api/interview/create-link",
      "rescheduleInterviewLink": "/api/interview/reschedule-link",
      "interviewAccess": "/api/interviews/{applicationId}/access-status",
      "interviewHeartbeat": "/api/interviews/{applicationId}/heartbeat",
      "interviewQuit": "/api/interviews/{applicationId}/quit",
      "interviewQuestions": "/api/interview/{applicationId}/questions",
      "interviewRegenerate": "/api/interview/questions/{applicationId}/regenerate",
      "interviewTranscribe": "/api/interview/{applicationId}/transcribe",
      "interviewStart": "/api/interview/{applicationId}/start",
      "interviewEvaluate": "/api/interview/questions/{applicationId}/evaluate",
      "interviewComplete": "/api/interview/questions/{applicationId}/complete",
      "interviewSaveAnswer": "/api/interviews/{applicationId}/answers/save",
      "livenessReference": "/api/interviews/{applicationId}/liveness/reference",
      "livenessCheck": "/api/interviews/{applicationId}/liveness/check",
      "interviewToken": "/api/interview/validate-token/{token}",
      "qwenHealth": "/api/interview/qwen-health",
      "faceVerify": "/api/interview/face-verify/{applicationId}",
      "identityUpload": "/api/kyc/identity/upload/{applicationId}",
      "candidateVerification": "/api/kyc/candidate/{applicationId}",
      "verificationStatus": "/api/kyc/verification-status/{applicationId}",
      "markVerified": "/api/kyc/verification/mark/{applicationId}",
      "candidateReport": "/api/hr/applications/{applicationId}/report",
      "reports": "/api/hr/reports"
    }
  },
  "features": {
    "acceptedResumeTypes": ".pdf,application/pdf",
    "acceptedIdTypes": ".jpg,.jpeg,.png,.pdf,image/jpeg,image/png,application/pdf",
    "defaultQuestionCount": 5,
    "maxQuestionCount": 50,
    "processingLeaveMessage": "Processing is still running. Are you sure you want to leave this page?"
  }
}
